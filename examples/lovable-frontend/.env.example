# Pluto BaaS — public keys, safe to ship to the browser
VITE_PLUTO_URL=https://api.timescard.cloud
VITE_PLUTO_ANON_KEY=pk_anon_replace_me

# Server-only. Use ONLY inside createServerFn / server routes.
# Never prefix with VITE_ or the bundler will leak it into browser code.
PLUTO_SERVICE_ROLE_KEY=sk_svc_replace_me
